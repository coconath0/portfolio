---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-logo">
      <span class="logo-circle">NMIL</span>
    </div>
    <p class="footer-copy">© {year} Nathaly Ingol. Crafted with ☕ & code.</p>
    <div class="footer-links">
      <a href="https://github.com/coconath0" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://linkedin.com/in/nathaly-ingol" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://instagram.com/coconath.png" target="_blank" rel="noopener noreferrer">Instagram</a>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--brown-dark);
  color: var(--cream);
  padding: 2.5rem 2rem;
}
.footer-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 1.5rem;
}
.logo-circle {
  display: inline-flex; align-items: center; justify-content: center;
  width: 52px; height: 52px; border-radius: 50%;
  background: var(--blush); color: var(--brown-dark);
  font-family: var(--font-serif); font-size: 0.8rem; font-weight: 700;
  letter-spacing: 0.05em;
}
.footer-copy { font-size: 0.85rem; opacity: 0.75; }
.footer-links { display: flex; gap: 1.5rem; }
.footer-links a {
  font-size: 0.85rem; opacity: 0.7; transition: opacity 0.2s;
}
.footer-links a:hover { opacity: 1; }

@media (max-width: 600px) {
  .footer-inner { flex-direction: column; text-align: center; }
  .footer-links { justify-content: center; flex-wrap: wrap; gap: 1rem 2rem; }
}

@media (max-width: 375px) {
  .footer { padding: 2rem 1.25rem; }
  .footer-copy { font-size: 0.8rem; }
}
</style>