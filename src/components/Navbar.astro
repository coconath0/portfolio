---
const navLinks = [
  { href: "/about", label: "About Me" },
  { href: "/resume", label: "Resume" },
  { href: "/projects", label: "Projects" },
];
const currentPath = Astro.url.pathname;
---
<nav class="navbar" id="navbar">
  <a href="/" class="nav-logo" aria-label="Home">Nathaly Ingol</a>
  <ul class="nav-links" role="list">
    {navLinks.map(link => (
      <li>
        <a href={link.href} class:list={["nav-link", { active: currentPath.startsWith(link.href) }]}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <a href="/contact" class="nav-cta">Contact Me</a>
  <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
  <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
    <button class="mobile-close" id="mobileClose" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <ul role="list">
      {navLinks.map(link => (
        <li><a href={link.href} class="mobile-link">{link.label}</a></li>
      ))}
      <li><a href="/contact" class="mobile-link mobile-cta">Contact Me</a></li>
    </ul>
  </div>
</nav>

<style>
.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: var(--nav-height); display: flex; align-items: center;
  padding: 0 2.5rem; background: var(--olive);
  transition: background 0.3s ease, box-shadow 0.3s ease;
}
.navbar.scrolled {
  background: rgba(75,90,42,0.96); backdrop-filter: blur(12px);
  box-shadow: 0 2px 20px rgba(0,0,0,0.15);
}
.nav-logo {
  font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700;
  color: var(--cream); margin-right: auto; letter-spacing: 0.02em;
  transition: opacity 0.2s;
}
.nav-logo:hover { opacity: 0.8; }
.nav-links { display: flex; gap: 3rem; list-style: none; margin-right: 2.5rem; }
.nav-link {
  font-size: 0.95rem; color: var(--cream); position: relative; transition: opacity 0.2s;
}
.nav-link::after {
  content: ''; position: absolute; bottom: -3px; left: 0;
  width: 0; height: 1.5px; background: var(--cream); transition: width 0.3s ease;
}
.nav-link:hover::after, .nav-link.active::after { width: 100%; }
.nav-cta {
  font-size: 0.9rem; font-weight: 500; color: var(--cream);
  background: var(--olive-dark); padding: 0.55rem 1.4rem;
  border-radius: 999px; transition: background 0.25s, color 0.25s, transform 0.2s;
}
.nav-cta:hover { background: var(--cream); color: var(--olive-dark); transform: translateY(-1px); }
/* Hamburger — hidden on desktop */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: none;
  /* 44×44 touch target (WCAG 2.5.5) */
  width: 44px;
  height: 44px;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  -webkit-tap-highlight-color: transparent;
}
.hamburger span {
  display: block; width: 24px; height: 2px;
  background: var(--cream); border-radius: 2px;
  transition: transform 0.3s, opacity 0.3s;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.mobile-menu {
  display: none;
  position: fixed;
  /* Anchor to very top so translateY(-100%) takes it fully off-screen */
  top: 0;
  left: 0; right: 0;
  background: var(--olive-dark);
  /* Push actual content below the navbar */
  padding: calc(var(--nav-height) + 1.5rem) 1.5rem 2.5rem;
  transform: translateY(-100%);
  transition: transform 0.35s ease;
  /* Below navbar (z-index 100) so it slides from underneath */
  z-index: 98;
}
.mobile-menu.open  { transform: translateY(0); }
.mobile-menu ul    { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
.mobile-link       { font-size: 1.15rem; color: var(--cream); padding: 0.25rem 0; display: block; }
.mobile-cta        { display: inline-block; background: var(--brown); padding: 0.6rem 1.5rem; border-radius: 999px; margin-top: 0.5rem; }
/* Close button inside the mobile menu */
.mobile-close {
  position: absolute;
  top: calc(var(--nav-height) + 0.5rem);
  right: 1.25rem;
  background: none;
  border: none;
  color: var(--cream);
  cursor: pointer;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s;
  -webkit-tap-highlight-color: transparent;
}
.mobile-close:hover { background: rgba(255,255,255,0.12); }

@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .hamburger { display: flex; }
  .mobile-menu { display: block; }
}

/* Compact navbar on very small screens */
@media (max-width: 375px) {
  .navbar { padding: 0 1.25rem; }
  .nav-logo { font-size: 1rem; }
}
</style>
<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  window.addEventListener('scroll', () => { navbar.classList.toggle('scrolled', window.scrollY > 20); });

  const mobileClose = document.getElementById('mobileClose');

  function toggleMenu(force?: boolean) {
    const isOpen = force !== undefined ? force : !hamburger.classList.contains('open');
    hamburger.classList.toggle('open', isOpen);
    mobileMenu.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    mobileMenu.setAttribute('aria-hidden', String(!isOpen));
    // Lock scroll without blocking fixed-element clicks (iOS-safe)
    document.documentElement.classList.toggle('menu-open', isOpen);
  }

  hamburger.addEventListener('click', () => toggleMenu());
  mobileClose.addEventListener('click', () => toggleMenu(false));

  // Close menu when a mobile link is tapped
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') toggleMenu(false);
  });
</script>