---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Nathaly Ingol | Software Engineer & Data Enthusiast",
  description = "Hi, I'm Nathaly Ingol. Senior CS student at Texas State University, Software engineer based in Austin, TX.",
  ogImage = "/images/og-cover.png",
} = Astro.props;

const SITE = 'https://nathalyingol.netlify.app';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE);
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta name="google-site-verification" content="SiyqrS8u5tDU__cOPb_0pEGnAwLFzX4aRjfxQtzNEJU" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#8B9A5A" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Nathaly Ingol" />
  <meta name="keywords" content="Nathaly Ingol, Software Engineer, Data Engineer, AI ML, Texas State University, TXST, Portfolio, Full Stack Developer, Austin Texas, coconath0" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Nathaly Ingol Portfolio" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Nathaly Ingol",
    "url": "https://nathalyingol.netlify.app",
    "jobTitle": "Software Engineer",
    "description": "Senior CS student at Texas State University seeking full-time roles in Software Engineering based in Austin, TX.",
    "alumniOf": { "@type": "CollegeOrUniversity", "name": "Texas State University" },
    "sameAs": [
      "https://github.com/coconath0",
      "https://www.linkedin.com/in/nathaly-ingol-leon",
      "https://www.instagram.com/coconath.png"
    ],
    "knowsAbout": ["Software Engineering", "Data Engineering", "Machine Learning", "Web Development", "Python", "JavaScript"]
  })} />

  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
</body>
</html>