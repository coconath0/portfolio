<BaseLayout
  title="Projects | Nathaly Ingol"
  description="A showcase of Nathaly Ingol's software engineering and data science projects."
>
  <Navbar />
  <main>

    <!-- HERO — carousel ════════-->
    <section class="projects-hero" aria-label="Projects">
      <div class="hero-watermark" aria-hidden="true">PROJECTS</div>

      <div class="carousel-wrapper">
        <button class="carousel-arrow carousel-prev" id="carouselPrev" aria-label="Scroll left">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="carousel-arrow carousel-next" id="carouselNext" aria-label="Scroll right">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <div class="carousel-track" id="carouselTrack">
          {projects.map((p) => (
            <a class="carousel-card" href={`#project-${p.id}`} aria-label={`Jump to ${p.title}`}>
              <div class="carousel-img">
                {p.image ? (
                  <img src={p.image} alt={p.title} />
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="1.1"
                    stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                )}
              </div>
              <div class="carousel-footer">
                <span class="c-num">{String(p.id).padStart(2, '0')}</span>
                <span class="c-name">{p.title}</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <p class="hero-tagline">Code. Design. Create.</p>
    </section>

    <script>
      const track = document.getElementById('carouselTrack')!;
      const prev  = document.getElementById('carouselPrev')!;
      const next  = document.getElementById('carouselNext')!;
      const STEP  = 300;

      prev.addEventListener('click', () => {
        track.scrollBy({ left: -STEP, behavior: 'smooth' });
      });
      next.addEventListener('click', () => {
        track.scrollBy({ left: STEP, behavior: 'smooth' });
      });

      // Mouse-wheel → horizontal scroll
      track.addEventListener('wheel', (e: WheelEvent) => {
        if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
          e.preventDefault();
          track.scrollBy({ left: e.deltaY * 1.2, behavior: 'auto' });
        }
      }, { passive: false });

      // Hide/show arrows based on scroll position
      function updateArrows() {
        prev.style.opacity = track.scrollLeft <= 10 ? '0.3' : '1';
        next.style.opacity = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10 ? '0.3' : '1';
      }
      track.addEventListener('scroll', updateArrows, { passive: true });
      updateArrows();
    </script>

    <!-- PROJECT DETAIL SECTIONS -->
    {projects.map((p) => (
      <section class="project-section" id={`project-${p.id}`} aria-label={p.title} style={`background:${p.sectionBg};`}>
        <div class:list={["proj-grid", `layout-${p.layout}`]}>

          <!-- Image card -->
          <div class="proj-card proj-image">
            {p.image ? (
              <img src={p.image} alt={p.title} />
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24"
                fill="none" stroke="#c5b8a8" stroke-width="0.8"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            )}
          </div>

          <!-- Title card -->
          <div class="proj-card proj-title" style={`background:${p.titleBg}; color:${p.titleColor};`}>
            {p.inProgress && <span class="badge-wip">In Progress</span>}
            <span class="proj-num">{p.id}.</span>
            <h2 class="proj-name">{p.title}.</h2>
            <p class="proj-sub">{p.subtitle}</p>
            <p class="proj-desc">{p.description}</p>
          </div>

          <!-- Tech card -->
          <!--
            TECH DISPLAY: two versions, both rendered 
            Icon badges are shown by default; pill tags are hidden.
            To SWITCH to pill tags → in the <style> block below, set:
              .tech-icons-row { display: none; }
              .tech-pills-row { display: flex;  }
          -->
          <div
            class:list={["proj-card", "proj-tech", { "tech-light": p.techLight }]}
            style={`background:${p.techBg};`}
          >
            <p class="tech-label">Technologies used in project</p>

            <!-- VERSION A - Icon badges (DEFAULT) -->
            <div class="tech-icons-row" aria-label="Technology badges">
              {p.technologies.map((t) => (
                t.icon ? (
                  <span class="tch-icon tch-icon-img" title={t.name} aria-label={t.name}>
                    <img src={t.icon} alt={t.name} width="26" height="26" loading="lazy" />
                    <span class="tch-name">{t.name}</span>
                  </span>
                ) : (
                  <span
                    class="tch-icon"
                    title={t.name}
                    aria-label={t.name}
                    style={`background:${t.color}; color:${isLight(t.color) ? '#2A1A0A' : '#ffffff'};`}
                  >
                    {t.abbr}
                    <span class="tch-name">{t.name}</span>
                  </span>
                )
              ))}
            </div>

            <!-- VERSION B - Text pills (hidden by default) -->
            <div class="tech-pills-row" aria-label="Technology names">
              {p.technologies.map((t) => (
                <span class="tech-pill">{t.name}</span>
              ))}
            </div>

            <div class="proj-btns">
              {p.live ? (
                <a href={p.live} class="btn-live" target="_blank" rel="noopener noreferrer">View Live →</a>
              ) : (
                <span class="btn-live btn-disabled">No Live Demo</span>
              )}
              <a href={p.github} class="btn-github" target="_blank" rel="noopener noreferrer">Github →</a>
            </div>
          </div>

          <!-- Topics card -->
          <div class="proj-card proj-topics">
            <p class="topics-label">Topics used / related to<br/>the implementation of this project</p>
            <div class="topics-tags">
              {p.topics.map((t) => (
                <span class="topic-tag">{t}</span>
              ))}
            </div>
          </div>

        </div>
      </section>
    ))}

  </main>
  <Footer />
</BaseLayout>

