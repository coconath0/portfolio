<style>
    /* PAGE WRAPPER */
    .vr-page {
        background: var(--olive);
        min-height: 100vh;
        padding: calc(var(--nav-height) + 2.5rem) 2rem 4rem;
        display: flex;
        justify-content: center;
        align-items: flex-start;
    }

    /* DOCUMENT CARD */
    .vr-doc {
        background: var(--cream);
        max-width: 960px;
        width: 100%;
        border-radius: 4px;
        box-shadow: 0 8px 48px rgba(0, 0, 0, 0.22);
        padding: 3.5rem 4rem;
    }

    /* HEADER */
    .vr-header {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 3rem;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .vr-name {
        font-family: var(--font-display);
        font-size: clamp(3rem, 5vw, 6rem);
        line-height: 0.9;
        color: var(--olive-dark);
        letter-spacing: 0.01em;
        margin: 0 0 0.6rem;
    }

    .vr-title {
        font-family: var(--font-body);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.13em;
        color: var(--olive-dark);
        margin-bottom: 1rem;
    }

    .vr-about {
        font-size: 0.88rem;
        color: var(--text-dark);
        line-height: 1.65;
        margin-bottom: 1.25rem;
        max-width: 480px;
    }

    .vr-contact-bar {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
    }
    .vr-contact-bar li {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: var(--brown);
    }
    .vr-contact-bar svg {
        opacity: 0.7;
        flex-shrink: 0;
    }

    /* Photo + download */
    .vr-header-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.85rem;
    }

    .vr-photo-frame {
        width: 160px;
        height: 190px;
        overflow: hidden;
        border-radius: 2px;
        border: 3px solid var(--olive);
        box-shadow: 4px 4px 0 var(--olive-dark);
        flex-shrink: 0;
    }
    .vr-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        filter: grayscale(30%);
    }

    .vr-download-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--olive-dark);
        color: var(--cream);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 0.5rem 1.1rem;
        border-radius: 999px;
        white-space: nowrap;
        transition:
            opacity 0.2s,
            transform 0.2s;
    }
    .vr-download-btn:hover {
        opacity: 0.85;
        transform: translateY(-1px);
    }

    /* DIVIDER */
    .vr-divider {
        height: 2px;
        background: var(--olive);
        border-radius: 1px;
        margin-bottom: 2.5rem;
        opacity: 0.5;
    }

    /* TWO-COLUMN BODY */
    .vr-body {
        display: grid;
        grid-template-columns: 1.55fr 1fr;
        gap: 3rem;
        align-items: start;
    }

    /* SECTION BASE */
    .vr-section {
        margin-bottom: 2rem;
    }

    .vr-section-title {
        font-family: var(--font-body);
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--olive-dark);
        border-bottom: 1.5px solid var(--olive);
        padding-bottom: 0.35rem;
        margin-bottom: 1rem;
    }

    /* EDUCATION */
    .vr-edu-item {
        margin-bottom: 1rem;
    }
    .vr-edu-degree {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--text-dark);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.1rem;
    }
    .vr-edu-school {
        font-size: 0.82rem;
        font-style: italic;
        color: var(--brown);
        margin-bottom: 0.1rem;
    }
    .vr-edu-detail {
        font-size: 0.78rem;
        color: var(--text-dark);
        opacity: 0.65;
    }

    /* EXPERIENCE */
    .vr-exp-item {
        margin-bottom: 1.1rem;
        padding-left: 0.85rem;
        border-left: 2px solid var(--olive);
    }
    .vr-exp-role {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--text-dark);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.1rem;
    }
    .vr-exp-org {
        font-size: 0.8rem;
        font-style: italic;
        color: var(--brown);
        margin-bottom: 0.3rem;
    }
    .vr-exp-desc {
        font-size: 0.8rem;
        color: var(--text-dark);
        line-height: 1.6;
        opacity: 0.85;
    }

    /* PROJECTS */
    .vr-proj-item {
        margin-bottom: 1rem;
        padding-left: 0.85rem;
        border-left: 2px solid var(--blush);
    }
    .vr-proj-name {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--text-dark);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.25rem;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.5rem;
    }
    .vr-proj-tech {
        font-size: 0.72rem;
        font-weight: 500;
        text-transform: none;
        letter-spacing: 0;
        color: var(--olive-dark);
        background: rgba(139, 154, 90, 0.12);
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
    }

    /* SKILLS TAGS */
    .vr-skills-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }
    .vr-skills-tags span {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--brown-dark);
        background: var(--white);
        border: 1px solid rgba(107, 58, 42, 0.25);
        border-radius: 999px;
